# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Ollama
OLLAMA_URL=http://localhost:11434
MODEL_NAME=llama3

# Konuşma geçmişi
MAX_HISTORY_PAIRS=10
SESSION_TTL_SECONDS=3600

# Nasri kişiliği (boş bırakılırsa sistem mesajı gönderilmez)
NASRI_SYSTEM_PROMPT=

# F12 — Güvenlik
# API anahtarı (boş bırakılırsa auth devre dışı — sadece geliştirme için)
NASRI_API_KEY=
# İzin verilen CORS originleri (virgülle ayrılmış)
NASRI_CORS_ORIGINS=http://localhost:5173
# Dakikada maksimum istek sayısı (per-IP)
NASRI_RATE_LIMIT_RPM=60
# F1.07 — RBAC (1=true, 0=false)
NASRI_RBAC_ENABLED=0
# Auth session TTL (saniye)
AUTH_SESSION_TTL_SECONDS=28800
# Kullanıcılar JSON (örnek)
# NASRI_USERS_JSON={"admin":{"password":"admin","role":"admin"},"viewer":{"password":"viewer","role":"viewer"}}

# API sunucu portu
NASRI_API_PORT=8000

# F1.11 — Dosya yönetimi
NASRI_FILES_ROOT=.
NASRI_FILES_MAX_RESULTS=200

# F1.04 — Whisper.cpp Türkçe STT
WHISPER_CPP_BINARY=
WHISPER_CPP_MODEL=
WHISPER_CPP_LANGUAGE=tr
WHISPER_CPP_TIMEOUT_SECONDS=180

# F1.05 — Piper TTS
PIPER_BINARY=
PIPER_MODEL=
PIPER_OUTPUT_SAMPLE_RATE=22050
PIPER_TIMEOUT_SECONDS=120

# F1.06 — Credential Vault (AES-256)
NASRI_VAULT_MASTER_KEY=
NASRI_VAULT_KEY_ID=v1

# F1.08 — Donanım kimliği + biyometrik eşleştirme
NASRI_DEVICE_FINGERPRINT_SALT=nasri-device-salt
NASRI_BIOMETRIC_SALT=nasri-biometric-salt

# F2.01 — RAG (ChromaDB + nomic-embed-text)
RAG_COLLECTION_NAME=nasri_docs
RAG_PERSIST_DIR=.nasri-rag
RAG_EMBEDDING_MODEL=nomic-embed-text
RAG_DEFAULT_TOP_K=5

# F2.02 — Long-term Memory Manager
MEMORY_COLLECTION_NAME=nasri_memory
MEMORY_DEFAULT_TOP_K=5
