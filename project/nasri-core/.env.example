# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Ollama
OLLAMA_URL=http://localhost:11434
MODEL_NAME=llama3

# Konuşma geçmişi
MAX_HISTORY_PAIRS=10
SESSION_TTL_SECONDS=3600

# Nasri kişiliği (boş bırakılırsa sistem mesajı gönderilmez)
NASRI_SYSTEM_PROMPT=

# F12 — Güvenlik
# API anahtarı (boş bırakılırsa auth devre dışı — sadece geliştirme için)
NASRI_API_KEY=
# İzin verilen CORS originleri (virgülle ayrılmış)
NASRI_CORS_ORIGINS=http://localhost:5173
# Dakikada maksimum istek sayısı (per-IP)
NASRI_RATE_LIMIT_RPM=60
# F1.07 — RBAC (1=true, 0=false)
NASRI_RBAC_ENABLED=0
# Auth session TTL (saniye)
AUTH_SESSION_TTL_SECONDS=28800
# Kullanıcılar JSON (örnek)
# NASRI_USERS_JSON={"admin":{"password":"admin","role":"admin"},"viewer":{"password":"viewer","role":"viewer"}}

# API sunucu portu
NASRI_API_PORT=8000

# F1.11 — Dosya yönetimi
NASRI_FILES_ROOT=.
NASRI_FILES_MAX_RESULTS=200

# F1.04 — Whisper.cpp Türkçe STT
WHISPER_CPP_BINARY=
WHISPER_CPP_MODEL=
WHISPER_CPP_LANGUAGE=tr
WHISPER_CPP_TIMEOUT_SECONDS=180

# F1.05 — Piper TTS
PIPER_BINARY=
PIPER_MODEL=
PIPER_OUTPUT_SAMPLE_RATE=22050
PIPER_TIMEOUT_SECONDS=120

# F1.06 — Credential Vault (AES-256)
NASRI_VAULT_MASTER_KEY=
NASRI_VAULT_KEY_ID=v1

# F1.08 — Donanım kimliği + biyometrik eşleştirme
NASRI_DEVICE_FINGERPRINT_SALT=nasri-device-salt
NASRI_BIOMETRIC_SALT=nasri-biometric-salt

# F2.01 — RAG (ChromaDB + nomic-embed-text)
RAG_COLLECTION_NAME=nasri_docs
RAG_PERSIST_DIR=.nasri-rag
RAG_EMBEDDING_MODEL=nomic-embed-text
RAG_DEFAULT_TOP_K=5

# F2.02 — Long-term Memory Manager
MEMORY_COLLECTION_NAME=nasri_memory
MEMORY_DEFAULT_TOP_K=5

# F2.03 — Planner (ReAct)
PLANNER_MAX_STEPS=6

# F2.04 — Model Router (local -> free -> paid)
MODEL_ROUTER_TIER_ORDER=local,free,paid
MODEL_ROUTER_FREE_ENABLED=1
MODEL_ROUTER_FREE_PROVIDER=groq
MODEL_ROUTER_FREE_API_URL=
MODEL_ROUTER_FREE_API_KEY=
MODEL_ROUTER_FREE_MODEL=
MODEL_ROUTER_PAID_ENABLED=0
MODEL_ROUTER_PAID_PROVIDER=openrouter
MODEL_ROUTER_PAID_API_URL=
MODEL_ROUTER_PAID_API_KEY=
MODEL_ROUTER_PAID_MODEL=

# F2.05 — External AI providers (Groq, Gemini, OpenRouter)
EXTERNAL_AI_ANONYMIZE_ENABLED=1

GROQ_API_KEY=
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.1-8b-instant
GROQ_RPM=60
GROQ_COST_INPUT_PER_1K=0
GROQ_COST_OUTPUT_PER_1K=0

GEMINI_API_KEY=
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models
GEMINI_MODEL=gemini-1.5-flash
GEMINI_RPM=30
GEMINI_COST_INPUT_PER_1K=0
GEMINI_COST_OUTPUT_PER_1K=0

OPENROUTER_API_KEY=
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_RPM=30
OPENROUTER_COST_INPUT_PER_1K=0
OPENROUTER_COST_OUTPUT_PER_1K=0

# F2.06 — LAN tarama (nmap + mDNS)
LAN_SCAN_DEFAULT_CIDR=192.168.1.0/24
LAN_SCAN_TIMEOUT_SECONDS=30
LAN_SCAN_MDNS_ENABLED=1

# F2.07 — SSH remote management
SSH_CONNECT_TIMEOUT_SECONDS=15

# F2.08 — Home Assistant + MQTT bridge
HOME_ASSISTANT_ENABLED=0
HOME_ASSISTANT_URL=http://localhost:8123
HOME_ASSISTANT_TOKEN=
HOME_ASSISTANT_DEFAULT_AREA=salon
MQTT_ENABLED=1
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=nasri

# F2.09 — System maintenance automation
MAINTENANCE_ENABLED=1
MAINTENANCE_INTERVAL_HOURS=24
MAINTENANCE_LOG_DIRS=logs,tmp
MAINTENANCE_LOG_RETENTION_DAYS=14
MAINTENANCE_AUTO_UPDATE_ENABLED=0
MAINTENANCE_UPDATE_COMMAND=
MAINTENANCE_DISK_PATHS=.
